# ========== 1. 本地服务（服务器请求处理）相关集合 ==========
# 允许访问本机服务的源 IP 地址（支持 CIDR 和单个 IP）
add set inet filter local_allow_sources { type ipv4_addr; flags interval; }
# 本机开放的 TCP 服务端口
add set inet filter local_tcp_services { type inet_service; }
# 本机开放的 UDP 服务端口（示例）
add set inet filter local_udp_services { type inet_service; }

# ========== 2. 代理转发（服务器请求转发）相关集合 ==========
# 允许被转发的源 IP 地址段
add set inet filter forward_sources { type ipv4_addr; flags interval; }
# 允许被转发的目标 IP 地址段（例如后端服务器网段）
add set inet filter forward_destinations { type ipv4_addr; flags interval; }
# 允许转发的目标端口
add set inet filter forward_ports { type inet_service; }

# ========== 3. 字典（map）示例：根据目标 IP 决定转发策略 ==========
# 例如：将外网 IP 1.2.3.4 映射到内网后端 192.168.100.10
add map inet filter dnat_map { type ipv4_addr : ipv4_addr; }
# 根据入站端口映射到不同内网端口（端口重定向）
add map inet filter port_redir_map { type inet_service : inet_service; }

# ------------------- 填充数据（示例，可按需修改）-------------------
# 本地服务允许的源 IP（管理网段或特定主机）
# add element inet filter local_allow_sources { 10.0.0.0/8, 192.168.1.0/24, 172.16.0.5 }
add element inet filter local_allow_sources { 192.168.154.149, 192.168.165.87 }
# 本机开放的服务端口（HTTP、HTTPS、SSH）
add element inet filter local_tcp_services { 22, 8076 }
# add element inet filter local_udp_services { 53, 123 }

# 转发允许的源（内部客户端子网）
# add element inet filter forward_sources { 192.168.10.0/24, 10.10.10.0/24 }
add element inet filter forward_sources { 192.168.154.149 }
# 转发允许的目标（后端服务器子网）
# add element inet filter forward_destinations { 172.20.0.0/16 }
add element inet filter forward_destinations { 192.168.165.89 }
# 允许转发的端口（例如 80,443 以及自定义代理端口）
# add element inet filter forward_ports { 80, 443, 3128, 8080 }
add element inet filter forward_ports { 8076 }

# DNAT 映射示例：公网 IP  -> 内网真实服务器
# add element inet filter dnat_map { 203.0.113.5 : 192.168.100.10, 203.0.113.6 : 192.168.100.20 }
# 端口重定向示例：访问主机 8080 映射到内网 80 端口（需结合 nat 表使用）
# add element inet filter port_redir_map { 8080 : 80, 8443 : 443 }
